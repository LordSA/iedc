---
import { Image as ImageIcon, Sparkles, MoveRight } from 'lucide-astro';

const spotlightImages = [
    { id: "01", image: "/gallery/img1.png", label: "Moment #01" },
    { id: "02", image: "/gallery/img2.png", label: "Moment #02" },
    { id: "03", image: "/gallery/img3.png", label: "Moment #03" },
    { id: "04", image: "/gallery/img1.png", label: "Moment #04" },
    { id: "05", image: "/gallery/img2.png", label: "Moment #05" },
];
---

<section id="gallery" class="bg-white py-26 overflow-hidden">
    <div class="container mx-auto px-6 mb-40">
        <div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-20 animate-on-scroll">
            <div class="max-w-2xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-50 text-blue-600 rounded-lg text-[10px] font-black uppercase tracking-[0.3em] mb-6">
                    <Sparkles class="w-3 h-3" />
                    Spotlight
                </div>
                <h2 class="text-5xl md:text-8xl font-black text-[#001F3F] uppercase italic font-montserrat leading-[0.9] tracking-tighter">
                    THE <span class="text-blue-600">GALLERY.</span>
                </h2>
            </div>
            <p class="text-gray-400 font-medium italic max-w-xs text-right">
                Capturing the energy and innovation of our campus ecosystem.
            </p>
        </div>


        <div class="relative overflow-visible" id="spotlight-wrapper">
            <div class="flex gap-8 w-max min-w-full" id="spotlight-scroll-content">
                {spotlightImages.map((item) => (
                    <div class="gallery-blank-card w-[400px] md:w-[600px] aspect-[16/10] bg-[#fafafa] border border-gray-100 rounded-[2.5rem] flex items-center justify-center group overflow-hidden relative flex-shrink-0">
                        {item.image ? (
                            <img src={item.image} alt={item.label} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                        ) : (
                            <ImageIcon class="w-12 h-12 text-gray-200 group-hover:scale-110 transition-transform duration-500" />
                        )}
                        <div class="absolute bottom-10 left-10 opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="text-[10px] font-black text-white/50 uppercase tracking-widest">{item.label}</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <div id="journey" class="container mx-auto px-6">
        <div class="text-center mb-32">
            <h3 class="text-4xl md:text-7xl font-black text-[#001F3F] uppercase italic font-montserrat tracking-tighter">
                THE <span class="text-blue-600">JOURNEY.</span>
            </h3>
            <div class="w-20 h-1.5 bg-blue-600 mx-auto mt-6 rounded-full"></div>
        </div>

        <div class="space-y-40">
            <div class="journey-item flex flex-col md:flex-row items-center gap-12 md:gap-24 opacity-0">
                <div class="w-full md:w-1/2 aspect-[4/3] bg-[#fafafa] border border-gray-100 rounded-[3rem] shadow-2xl shadow-gray-200/50 flex items-center justify-center overflow-hidden relative journey-visual">
                    <img src="/bootcamp2.png" alt="Bootcamp 2" class="w-full h-full object-cover" />
                    <div class="absolute top-10 left-10 text-[60px] font-black text-black/5 italic select-none">2025</div>
                </div>
                <div class="w-full md:w-1/2 space-y-6">
                    <h4 class="text-3xl md:text-5xl font-black text-[#001F3F] uppercase italic font-montserrat leading-tight">Onward<br/>2.0</h4>
                    <p class="text-lg text-gray-400 font-medium leading-relaxed italic">The initial steps of building a core community of innovators with first years at CEV.</p>
                </div>
            </div>

            <div class="journey-item flex flex-col md:flex-row-reverse items-center gap-12 md:gap-24 opacity-0">
                <div class="w-full md:w-1/2 aspect-[4/3] bg-[#fafafa] border border-gray-100 rounded-[3rem] shadow-2xl shadow-gray-200/50 flex items-center justify-center overflow-hidden relative journey-visual">
                    <img src="/bootcamp1.png" alt="Bootcamp 1" class="w-full h-full object-cover" />
                    <div class="absolute top-10 left-10 text-[60px] font-black text-black/5 italic select-none">2025</div>
                </div>
                <div class="w-full md:w-1/2 space-y-6 text-left md:text-right">
                    <h4 class="text-3xl md:text-5xl font-black text-[#001F3F] uppercase italic font-montserrat leading-tight">Onward</h4>
                    <p class="text-lg text-gray-400 font-medium leading-relaxed italic">Expanding our reach and launching the first official Bootcamp series.</p>
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    import gsap from 'gsap';
    import ScrollTrigger from 'gsap/ScrollTrigger';
    
    gsap.registerPlugin(ScrollTrigger);

    const initGSAP = () => {
        const scrollContent = document.querySelector("#spotlight-scroll-content");
        const scrollWrapper = document.querySelector("#spotlight-wrapper");
        
        if (scrollContent && scrollWrapper) {
            const amountToScroll = scrollContent.scrollWidth - scrollWrapper.clientWidth;
            
            gsap.to(scrollContent, {
                x: -amountToScroll,
                ease: "none",
                scrollTrigger: {
                    trigger: "#gallery",
                    start: "top top",
                    end: () => `+=${amountToScroll * 0.8}`,
                    pin: true,
                    scrub: 1,
                    anticipatePin: 1,
                    invalidateOnRefresh: true,
                }
            });
        }

        gsap.from(".gallery-blank-card", {
            scrollTrigger: {
                trigger: "#spotlight-wrapper",
                start: "top 80%",
            },
            y: 60,
            opacity: 0,
            duration: 1,
            stagger: 0.1,
            ease: "power4.out"
        });

        const journeyItems = document.querySelectorAll('.journey-item');
        journeyItems.forEach((item, index) => {
            const visual = item.querySelector('.journey-visual');
            
            gsap.to(item, {
                scrollTrigger: {
                    trigger: item,
                    start: "top 85%",
                    end: "top 20%",
                    toggleActions: "play none none reverse"
                },
                opacity: 1,
                y: 0,
                duration: 1.2,
                ease: "expo.out"
            });

            gsap.to(visual, {
                scrollTrigger: {
                    trigger: item,
                    start: "top bottom",
                    end: "bottom top",
                    scrub: 1
                },
                y: index % 2 === 0 ? -40 : 40,
                rotate: index % 2 === 0 ? -2 : 2,
                ease: "none"
            });
        });
    };

    initGSAP();

    document.addEventListener('astro:after-swap', () => {
        ScrollTrigger.getAll().forEach(t => t.kill());
        initGSAP();
        ScrollTrigger.refresh();
    });
</script>

<style>
    /* Ensure journey items start slightly lower for the entrance animation */
    .journey-item {
        transform: translateY(40px);
    }
</style>
