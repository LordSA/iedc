---
const events = [
    { title: "IEDC Summit", year: "2025", image: "https://images.unsplash.com/photo-1540575861501-7cf05a4b125a?q=80&w=800&h=600&auto=format&fit=crop" },
    { title: "Hack to Future", year: "2024", image: "https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=800&h=600&auto=format&fit=crop" },
    { title: "Maker Weekend", year: "2024", image: "https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=800&h=600&auto=format&fit=crop" },
    { title: "Startup Saturday", year: "2023", image: "https://images.unsplash.com/photo-1475721027785-f74eccf877e2?q=80&w=800&h=600&auto=format&fit=crop" },
    { title: "Tech Fest", year: "2023", image: "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?q=80&w=800&h=600&auto=format&fit=crop" },
    { title: "Idea Pitch", year: "2022", image: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=800&h=600&auto=format&fit=crop" },
];
---

<section id="gallery" class="py-40 bg-white text-[#1A1A1A] overflow-hidden relative">
    <div class="container mx-auto px-6 mb-24 text-center">
        <div class="inline-block px-4 py-1.5 bg-gray-50 text-gray-400 text-[10px] font-black uppercase tracking-[0.3em] mb-8 rounded-lg border border-gray-100">
            Our Journey
        </div>
        <h2 class="text-5xl md:text-8xl font-black font-montserrat uppercase italic leading-[0.8] mb-6">
            BOOTCAMP <span class="text-blue-600">CHRONICLES.</span>
        </h2>
        <p class="text-gray-400 font-medium max-w-xl mx-auto uppercase tracking-wider text-sm">
            Reliving the energy from our previous executive committee bootcamps.
        </p>
    </div>

    <!-- Parallax Stacked Cards Design -->
    <div class="container mx-auto px-6 max-w-7xl" id="gallery-container">
        <div class="space-y-[40vh] pb-[40vh]">
            {events.map((event, index) => (
                <div class="gallery-item relative grid grid-cols-1 lg:grid-cols-12 items-center gap-12 group">
                    <div class={`lg:col-span-7 overflow-hidden rounded-[2.5rem] shadow-2xl shadow-blue-900/10 ${index % 2 === 0 ? 'lg:order-1' : 'lg:order-2'}`}>
                        <div class="image-wrapper relative aspect-[16/10] overflow-hidden">
                            <img 
                                src={event.image} 
                                alt={event.title} 
                                class="w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105"
                            />
                            <div class="absolute inset-0 bg-blue-600/10 mix-blend-overlay group-hover:bg-transparent transition-colors"></div>
                        </div>
                    </div>

                    <div class={`lg:col-span-5 space-y-6 ${index % 2 === 0 ? 'lg:order-2 lg:pl-12' : 'lg:order-1 lg:pr-12 lg:text-right'}`}>
                        <span class="text-7xl md:text-9xl font-black text-gray-50 font-montserrat italic absolute -top-20 right-0 -z-10 select-none opacity-0 group-hover:opacity-100 transition-opacity duration-700">
                            0{index + 1}
                        </span>
                        
                        <div class="space-y-2">
                             <span class="text-blue-600 font-black text-sm uppercase tracking-[0.3em] font-montserrat italic block translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                                {event.year}
                             </span>
                             <h4 class="text-4xl md:text-6xl font-black font-montserrat uppercase italic leading-none text-[#001F3F]">
                                {event.title}
                             </h4>
                        </div>
                        
                        <div class={`h-1 w-20 bg-blue-600 rounded-full group-hover:w-full transition-all duration-1000 ${index % 2 === 0 ? '' : 'ml-auto'}`}></div>
                        
                        <p class="text-gray-400 font-medium leading-relaxed italic opacity-0 group-hover:opacity-100 transition-opacity duration-1000 delay-300">
                            Pushing the boundaries of what is possible within the student ecosystem of College of Engineering Vadakara.
                        </p>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- Large Background Text -->
    <div class="absolute bottom-0 right-0 text-[30vw] font-black text-gray-50 leading-none whitespace-nowrap select-none pointer-events-none uppercase italic font-montserrat -z-10 translate-y-1/2">
        MOMENTS
    </div>
</section>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Staggered entrance for items
    gsap.utils.toArray('.gallery-item').forEach((item: any) => {
        gsap.from(item.querySelector('.image-wrapper'), {
            y: 100,
            opacity: 0,
            duration: 1.5,
            ease: "power4.out",
            scrollTrigger: {
                trigger: item,
                start: "top 80%",
            }
        });

        gsap.from(item.querySelector('.lg:col-span-5'), {
            x: item.querySelector('.lg:text-right') ? -50 : 50,
            opacity: 0,
            duration: 1.2,
            delay: 0.3,
            ease: "power3.out",
            scrollTrigger: {
                trigger: item,
                start: "top 75%",
            }
        });
    });

    // Parallax effect for the background text
    gsap.to('.absolute.bottom-0.right-0', {
        x: '-20%',
        scrollTrigger: {
            trigger: '#gallery',
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1
        }
    });
</script>

<style>
    .gallery-item {
        will-change: transform, opacity;
    }
</style>
