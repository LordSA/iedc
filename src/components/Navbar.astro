---
import { Menu, X, ArrowRight } from 'lucide-astro';
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-300 bg-white/95 backdrop-blur-md border-b border-gray-100 shadow-sm" id="navbar-container">
    <div class="container mx-auto px-6">
        <nav class="flex justify-between items-center py-4 md:py-5" id="navbar-main">
            <a href="/" class="flex items-center gap-3 transition-transform hover:scale-[1.02]">
                <img src="/logo.png" alt="Logo" class="h-9 w-auto md:h-11" />
                <h4 class="text-xl md:text-2xl font-black font-montserrat uppercase leading-none tracking-tighter text-[#001F3F]">
                    IEDC <span class="text-blue-600">BOOTCAMP</span>
                </h4>
            </a>

            <!-- Desktop Menu -->
            <ul class="hidden md:flex items-center gap-10">
                <li><a href="/" class="text-[13px] font-bold uppercase tracking-widest text-[#001F3F] hover:text-blue-600 transition-colors">Home</a></li>
                <li><a href="#about" class="text-[13px] font-bold uppercase tracking-widest text-[#001F3F] hover:text-blue-600 transition-colors">Vision</a></li>
                <li><a href="#gallery" class="text-[13px] font-bold uppercase tracking-widest text-[#001F3F] hover:text-blue-600 transition-colors">Chronicles</a></li>
                <li>
                    <a href="/register" class="bg-[#001F3F] text-white px-8 py-3 rounded-lg hover:bg-blue-600 transition-all duration-300 font-bold text-[12px] uppercase tracking-widest flex items-center gap-2 group">
                        Register
                        <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                    </a>
                </li>
            </ul>
            
            <button class="md:hidden p-2 text-[#001F3F]" id="mobile-menu-btn" aria-label="Toggle Menu">
                <Menu id="menu-icon" class="w-7 h-7" />
                <X id="close-icon" class="w-7 h-7 hidden" />
            </button>
        </nav>
    </div>

    <!-- Mobile Menu Overlay -->
    <div 
        id="mobile-menu-overlay" 
        class="fixed inset-0 top-[76px] bg-white z-[40] translate-x-full transition-transform duration-500 ease-in-out md:hidden flex flex-col pt-12 px-6 shadow-2xl"
    >
        <ul class="space-y-6">
            <li><a href="/" class="mobile-link text-3xl font-black font-montserrat uppercase text-[#001F3F]">Home</a></li>
            <li><a href="#about" class="mobile-link text-3xl font-black font-montserrat uppercase text-[#001F3F]">Vision</a></li>
            <li><a href="#gallery" class="mobile-link text-3xl font-black font-montserrat uppercase text-[#001F3F]">Chronicles</a></li>
        </ul>
        
        <div class="mt-12">
            <a href="/register" class="w-full bg-blue-600 text-white p-6 rounded-xl text-center font-black text-xl uppercase tracking-widest flex items-center justify-center gap-3 active:scale-95 transition-transform shadow-xl shadow-blue-500/20">
                Register Now
                <ArrowRight class="w-6 h-6" />
            </a>
        </div>

        <div class="mt-auto mb-12 text-center">
            <p class="text-[10px] uppercase tracking-[0.3em] font-extrabold text-[#001F3F]/30">IEDC CEV Bootcamp 2026</p>
        </div>
    </div>
</header>

<script>
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const navbar = document.getElementById('navbar-container');

    let isMenuOpen = false;

    const toggleMenu = () => {
        isMenuOpen = !isMenuOpen;
        mobileMenuOverlay?.classList.toggle('translate-x-full');
        menuIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
        document.body.style.overflow = isMenuOpen ? 'hidden' : 'auto';
    };

    mobileMenuBtn?.addEventListener('click', toggleMenu);
    mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));

    window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
            navbar?.classList.add('shadow-md');
            navbar?.classList.remove('shadow-sm');
        } else {
            navbar?.classList.add('shadow-sm');
            navbar?.classList.remove('shadow-md');
        }
    });
</script>

<style>
    /* Content spacing */
    :global(body) {
        padding-top: 80px;
    }
    @media (max-width: 768px) {
        :global(body) {
            padding-top: 76px;
        }
    }
</style>
