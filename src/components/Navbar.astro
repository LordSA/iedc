---
import { Menu, X, ArrowRight } from 'lucide-astro';
---

<nav 
  id="nav-wrapper"
  class="fixed top-0 inset-x-0 z-[100] transition-all duration-700 ease-[0.23,1,0.32,1] py-6 px-4 md:px-10"
>
  <div 
    id="nav-container"
    class="max-w-7xl mx-auto transition-all duration-700 ease-[0.23,1,0.32,1] rounded-[2rem] bg-transparent px-0 h-16 flex justify-between items-center"
  >
    <a href="/" class="nav-logo flex items-center group relative overflow-hidden transition-transform duration-500 hover:scale-105">
      <div class="relative h-9 w-32">
        <img
          src="/logo.png"
          alt="IEDC CEV Logo"
          class="h-full w-full object-contain"
        />
      </div>
    </a>

    <div class="hidden md:flex items-center space-x-2">
      <ul class="flex items-center">
        <li>
          <a href="/" class="nav-item relative px-5 py-2 text-sm font-medium tracking-wide transition-colors duration-500 group text-gray-600 hover:text-[#1A4C96]">
            <span class="relative z-10">Home</span>
            <div class="absolute inset-0 bg-blue-50/50 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out -z-0"></div>
          </a>
        </li>
        <li>
          <a href="/#about" class="nav-item relative px-5 py-2 text-sm font-medium tracking-wide transition-colors duration-500 group text-gray-600 hover:text-[#1A4C96]">
            <span class="relative z-10">Events</span>
            <div class="absolute inset-0 bg-blue-50/50 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out -z-0"></div>
          </a>
        </li>
        <li>
          <a href="/#gallery" class="nav-item relative px-5 py-2 text-sm font-medium tracking-wide transition-colors duration-500 group text-gray-600 hover:text-[#1A4C96]">
            <span class="relative z-10">Gallery</span>
            <div class="absolute inset-0 bg-blue-50/50 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out -z-0"></div>
          </a>
        </li>
      </ul>

      <div class="nav-item pl-4">
        <a
          href="https://www.iedccev.org/join"
          class="group relative inline-flex items-center justify-center px-7 py-3 overflow-hidden font-medium text-white transition-all duration-500 bg-[#001F3F] rounded-full hover:shadow-lg hover:shadow-blue-900/20"
        >
          <span class="absolute inset-0 w-full h-full transition-all duration-500 ease-out bg-[#1A4C96] -translate-x-full group-hover:translate-x-0"></span>
          <span class="relative flex items-center gap-2 text-sm tracking-widest uppercase">
            Join Us <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </span>
        </a>
      </div>
    </div>

      <button
        id="menu-toggle"
        class="nav-item md:hidden w-12 h-12 flex flex-col items-center justify-center gap-1.5 rounded-full hover:bg-white/10 transition-colors group"
        aria-label="Toggle Menu"
      >
        <div id="line-1" class="w-6 h-0.5 bg-[#001F3F] transition-all duration-500"></div>
        <div id="line-2" class="w-6 h-0.5 bg-[#001F3F] transition-all duration-300"></div>
        <div id="line-3" class="w-6 h-0.5 bg-[#001F3F] transition-all duration-500"></div>
      </button>
  </div>

  <div 
    id="mobile-overlay"
    class="fixed inset-0 bg-white z-[110] transition-all duration-700 ease-[0.85,0,0.15,1] -translate-y-full pointer-events-none flex flex-col items-center justify-center"
  >
    <button 
      id="close-toggle"
      class="absolute top-8 right-8 w-14 h-14 rounded-full flex items-center justify-center hover:bg-gray-50 transition-colors border border-gray-100"
    >
      <X class="h-6 w-6 text-[#001F3F]" />
    </button>

    <div class="flex flex-col items-center space-y-8 relative z-10 w-full px-6 text-center">
      <a href="/" class="mobile-link nav-link-anim text-4xl font-black font-montserrat uppercase italic text-[#001F3F] hover:text-blue-600 transition-colors tracking-tighter">
        Home
      </a>
      <a href="#about" class="mobile-link nav-link-anim text-4xl font-black font-montserrat uppercase italic text-[#001F3F] hover:text-blue-600 transition-colors tracking-tighter">
        About
      </a>
      <a href="#gallery" class="mobile-link nav-link-anim text-4xl font-black font-montserrat uppercase italic text-[#001F3F] hover:text-blue-600 transition-colors tracking-tighter">
        Gallery
      </a>
      <a 
        href="/register" 
        class="mobile-link nav-link-reg px-12 py-5 bg-[#1A4C96] text-white rounded-full text-xs font-black uppercase italic tracking-tighter hover:bg-blue-700 transition-all shadow-[0_20px_40px_rgba(26,76,150,0.3)] mt-4 inline-block"
      >
        Register Now
      </a>
    </div>

    <div class="absolute bottom-12 flex gap-8">
      <a href="https://instagram.com/iedc_cev" target="_blank" class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-400 hover:text-blue-600 transition-colors">Instagram</a>
      <a href="https://linkedin.com/company/iedc-cev" target="_blank" class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-400 hover:text-blue-600 transition-colors">LinkedIn</a>
    </div>
  </div>
</nav>

<script>
  import gsap from 'gsap';

  const setupNav = () => {
    const wrapper = document.getElementById('nav-wrapper');
    const container = document.getElementById('nav-container');
    const menuToggle = document.getElementById('menu-toggle');
    const closeToggle = document.getElementById('close-toggle');
    const mobileOverlay = document.getElementById('mobile-overlay');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    
    const line1 = document.getElementById('line-1');
    const line2 = document.getElementById('line-2');
    const line3 = document.getElementById('line-3');

    let isOpen = false;

    const toggleMenu = () => {
      if (!mobileOverlay) return;
      isOpen = !isOpen;
      
      if (isOpen) {
        mobileOverlay.classList.remove('-translate-y-full', 'pointer-events-none');
        mobileOverlay.classList.add('translate-y-0', 'pointer-events-auto');
        line1?.classList.add('rotate-45', 'translate-y-2');
        line2?.classList.add('opacity-0');
        line3?.classList.add('-rotate-45', '-translate-y-1.5');
        document.body.style.overflow = 'hidden';

        gsap.from(".nav-link-anim", {
          y: 60,
          opacity: 0,
          duration: 0.8,
          stagger: 0.1,
          ease: "power3.out",
          delay: 0.2
        });

        gsap.fromTo(".nav-link-reg", 
          {
            y: 40,
            opacity: 0
          },
          {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
            delay: 0.5,
            clearProps: "all"
          }
        ); 
      } else {
        mobileOverlay.classList.remove('translate-y-0', 'pointer-events-auto');
        mobileOverlay.classList.add('-translate-y-full', 'pointer-events-none');
        line1?.classList.remove('rotate-45', 'translate-y-2');
        line2?.classList.remove('opacity-0');
        line3?.classList.remove('-rotate-45', '-translate-y-1.5');
        document.body.style.overflow = '';
      }
    };

    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      if (currentScrollY > 40) {
        if (wrapper?.classList.contains('py-6')) {
          wrapper?.classList.remove('py-6');
          wrapper?.classList.add('py-3');
          container?.classList.add('bg-white/40', 'backdrop-blur-2xl', 'shadow-[0_8px_32px_0_rgba(31,38,135,0.07)]', 'border', 'border-white/40', 'px-6');
          container?.classList.remove('bg-transparent', 'px-0');
        }
      } else if (currentScrollY <= 10) {
        if (wrapper?.classList.contains('py-3')) {
          wrapper?.classList.remove('py-3');
          wrapper?.classList.add('py-6');
          container?.classList.remove('bg-white/40', 'backdrop-blur-2xl', 'shadow-[0_8px_32px_0_rgba(31,38,135,0.07)]', 'border', 'border-white/40', 'px-6');
          container?.classList.add('bg-transparent', 'px-0');
        }
      }
    });

    menuToggle?.addEventListener('click', (e) => {
      e.preventDefault();
      toggleMenu();
    });
    
    closeToggle?.addEventListener('click', (e) => {
      e.preventDefault();
      toggleMenu();
    });
    
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        setTimeout(() => {
          toggleMenu();
        }, 100);
      });
    });

    gsap.from(".nav-item", {
      y: -10,
      opacity: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: "power4.out",
      delay: 0.2
    });
    
    gsap.from(".nav-logo", {
      x: -10,
      opacity: 0,
      duration: 1,
      ease: "power4.out"
    });
  };

  setupNav();

  document.addEventListener('astro:after-swap', setupNav);
</script>

<style>
  :global(body) {
    padding-top: 0;
  }
</style>
