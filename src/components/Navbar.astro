---
import { Menu, X, ArrowRight } from 'lucide-astro';
---

<nav 
  id="nav-wrapper"
  class="fixed top-0 inset-x-0 z-[100] transition-all duration-700 ease-[0.23,1,0.32,1] py-6 px-4 md:px-10"
>
  <div 
    id="nav-container"
    class="max-w-7xl mx-auto transition-all duration-700 ease-[0.23,1,0.32,1] rounded-[2rem] bg-transparent px-0 h-16 flex justify-between items-center"
  >
    <!-- Logo -->
    <a href="/" class="nav-logo flex items-center group relative overflow-hidden transition-transform duration-500 hover:scale-105">
      <div class="relative h-9 w-32">
        <img
          src="/logo.png"
          alt="IEDC CEV Logo"
          class="h-full w-full object-contain"
        />
      </div>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center space-x-2">
      <ul class="flex items-center">
        <li>
          <a href="/" class="nav-item relative px-5 py-2 text-sm font-medium tracking-wide transition-colors duration-500 group text-gray-600 hover:text-[#1A4C96]">
            <span class="relative z-10">Home</span>
            <div class="absolute inset-0 bg-blue-50/50 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out -z-0"></div>
          </a>
        </li>
        <li>
          <a href="#about" class="nav-item relative px-5 py-2 text-sm font-medium tracking-wide transition-colors duration-500 group text-gray-600 hover:text-[#1A4C96]">
            <span class="relative z-10">Events</span>
            <div class="absolute inset-0 bg-blue-50/50 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out -z-0"></div>
          </a>
        </li>
        <li>
          <a href="#gallery" class="nav-item relative px-5 py-2 text-sm font-medium tracking-wide transition-colors duration-500 group text-gray-600 hover:text-[#1A4C96]">
            <span class="relative z-10">Chronicles</span>
            <div class="absolute inset-0 bg-blue-50/50 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out -z-0"></div>
          </a>
        </li>
      </ul>

      <div class="nav-item pl-4">
        <a
          href="/register"
          class="group relative inline-flex items-center justify-center px-7 py-3 overflow-hidden font-medium text-white transition-all duration-500 bg-[#001F3F] rounded-full hover:shadow-lg hover:shadow-blue-900/20"
        >
          <span class="absolute inset-0 w-full h-full transition-all duration-500 ease-out bg-[#1A4C96] -translate-x-full group-hover:translate-x-0"></span>
          <span class="relative flex items-center gap-2 text-sm tracking-widest uppercase">
            Join Hub <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </span>
        </a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="nav-item md:hidden w-12 h-12 flex flex-col items-center justify-center gap-1.5 rounded-full hover:bg-blue-50 transition-colors group"
      aria-label="Toggle Menu"
    >
      <div id="line-1" class="w-6 h-0.5 bg-[#001F3F] transition-all duration-500"></div>
      <div id="line-2" class="w-6 h-0.5 bg-[#001F3F] transition-all duration-300"></div>
      <div id="line-3" class="w-6 h-0.5 bg-[#001F3F] transition-all duration-500"></div>
    </button>
  </div>

  <!-- Full-screen Mobile Menu (Awwwards Style) -->
  <div 
    id="mobile-overlay"
    class="fixed inset-0 bg-white z-[110] transition-all duration-700 ease-[0.85,0,0.15,1] translate-y-full pointer-events-none overflow-y-auto"
  >
    <div class="min-h-full flex flex-col justify-between py-20 px-8 md:px-20 relative">
      <button 
        id="close-toggle"
        class="absolute top-6 right-6 md:top-10 md:right-10 w-12 h-12 md:w-16 md:h-16 border border-gray-100 rounded-full flex items-center justify-center hover:bg-gray-50 transition-colors"
      >
        <X class="h-6 w-6 md:h-8 md:w-8 text-[#001F3F]" />
      </button>

      <div class="space-y-12 mt-10 md:mt-0">
        <p class="text-[#1A4C96] text-xs md:text-sm font-bold tracking-[0.3em] uppercase">Navigation</p>
        <div class="flex flex-col space-y-6 md:space-y-4">
          <a href="/" class="mobile-link group flex items-center text-[#001F3F]">
            <span class="text-gray-300 text-lg md:text-2xl font-light mr-4 md:mr-6 font-montserrat">01</span>
            <span class="text-4xl md:text-7xl font-medium tracking-tight hover:text-[#1A4C96] transform group-hover:translate-x-4 transition-all duration-500">Home</span>
          </a>
          <a href="#about" class="mobile-link group flex items-center text-[#001F3F]">
            <span class="text-gray-300 text-lg md:text-2xl font-light mr-4 md:mr-6 font-montserrat">02</span>
            <span class="text-4xl md:text-7xl font-medium tracking-tight hover:text-[#1A4C96] transform group-hover:translate-x-4 transition-all duration-500">Vision</span>
          </a>
          <a href="#gallery" class="mobile-link group flex items-center text-[#001F3F]">
            <span class="text-gray-300 text-lg md:text-2xl font-light mr-4 md:mr-6 font-montserrat">03</span>
            <span class="text-4xl md:text-7xl font-medium tracking-tight hover:text-[#1A4C96] transform group-hover:translate-x-4 transition-all duration-500">Chronicles</span>
          </a>
        </div>
      </div>

      <div class="mt-20 md:mt-0 flex flex-col md:flex-row justify-between items-start md:items-end gap-12 md:gap-10 pb-10">
        <div class="space-y-4 text-left">
          <p class="text-gray-400 text-[10px] md:text-xs font-bold tracking-widest uppercase">Connectivity</p>
          <div class="flex gap-8 text-lg md:text-xl">
            <a href="https://instagram.com/iedc_cev" target="_blank" class="text-[#001F3F] hover:text-[#1A4C96] transition-colors">Instagram</a>
            <a href="https://linkedin.com/company/iedc-cev" target="_blank" class="text-[#001F3F] hover:text-[#1A4C96] transition-colors">LinkedIn</a>
          </div>
        </div>
        
        <a href="/register" class="mobile-link group flex flex-col text-left">
          <p class="text-gray-400 text-[10px] md:text-xs font-bold tracking-widest uppercase mb-4">Start your journey</p>
          <span class="text-3xl md:text-5xl font-medium flex items-center gap-4 md:gap-6 text-[#001F3F] group-hover:text-[#1A4C96] transition-colors">
            Join our IEDC Hub <ArrowRight class="h-8 w-8 md:h-10 md:w-10 group-hover:translate-x-4 transition-transform" />
          </span>
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  import gsap from 'gsap';

  const wrapper = document.getElementById('nav-wrapper');
  const container = document.getElementById('nav-container');
  const menuToggle = document.getElementById('menu-toggle');
  const closeToggle = document.getElementById('close-toggle');
  const mobileOverlay = document.getElementById('mobile-overlay');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  
  const line1 = document.getElementById('line-1');
  const line2 = document.getElementById('line-2');
  const line3 = document.getElementById('line-3');

  // Scroll logic with smoother threshold
  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;
    
    if (currentScrollY > 40) {
      if (wrapper?.classList.contains('py-6')) {
        wrapper?.classList.remove('py-6');
        wrapper?.classList.add('py-3');
        container?.classList.add('bg-white/40', 'backdrop-blur-2xl', 'shadow-[0_8px_32px_0_rgba(31,38,135,0.07)]', 'border', 'border-white/40', 'px-6');
        container?.classList.remove('bg-transparent', 'px-0');
      }
    } else if (currentScrollY <= 10) {
      if (wrapper?.classList.contains('py-3')) {
        wrapper?.classList.remove('py-3');
        wrapper?.classList.add('py-6');
        container?.classList.remove('bg-white/40', 'backdrop-blur-2xl', 'shadow-[0_8px_32px_0_rgba(31,38,135,0.07)]', 'border', 'border-white/40', 'px-6');
        container?.classList.add('bg-transparent', 'px-0');
      }
    }
  });

  // Mobile Menu Logic
  let isOpen = false;
  const toggleMenu = () => {
    isOpen = !isOpen;
    if (isOpen) {
      mobileOverlay?.classList.replace('translate-y-full', 'translate-y-0');
      mobileOverlay?.classList.replace('pointer-events-none', 'pointer-events-auto');
      line1?.classList.add('rotate-45', 'translate-y-2');
      line2?.classList.add('opacity-0');
      line3?.classList.add('-rotate-45', '-translate-y-1.5');
      document.body.style.overflow = 'hidden';
    } else {
      mobileOverlay?.classList.replace('translate-y-0', 'translate-y-full');
      mobileOverlay?.classList.replace('pointer-events-auto', 'pointer-events-none');
      line1?.classList.remove('rotate-45', 'translate-y-2');
      line2?.classList.remove('opacity-0');
      line3?.classList.remove('-rotate-45', '-translate-y-1.5');
      document.body.style.overflow = 'auto';
    }
  };

  menuToggle?.addEventListener('click', toggleMenu);
  closeToggle?.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));

  // Entrance Animations
  gsap.from(".nav-item", {
    y: -10,
    opacity: 0,
    duration: 0.8,
    stagger: 0.1,
    ease: "power4.out",
    delay: 0.2
  });
  
  gsap.from(".nav-logo", {
    x: -10,
    opacity: 0,
    duration: 1,
    ease: "power4.out"
  });
</script>

<style>
  :global(body) {
    padding-top: 0;
  }
</style>
