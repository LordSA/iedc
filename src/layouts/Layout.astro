---
interface Props {
	title: string;
}

const { title } = Astro.props;
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="IEDC Bootcamp 2026" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Montserrat:wght@700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FAFAFA] text-[#1A1A1A] font-sans antialiased overflow-x-hidden selection:bg-blue-600 selection:text-white">
		<slot />
		<style is:global>
			:root {
				--primary: #001F3F;
				--accent: #2563EB;
				--bg: #FAFAFA;
				--foreground: #1A1A1A;
			}
			html {
				scroll-behavior: smooth;
				font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
			}
			body {
				margin: 0;
				padding: 0;
				background-color: var(--bg);
				color: var(--foreground);
			}
			h1, h2, h3, .font-montserrat {
				font-family: 'Montserrat', sans-serif;
				letter-spacing: -0.02em;
			}
		</style>
	</body>
</html>
